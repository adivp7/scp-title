{
  "name": "SCP-Title",
  "description": "Gets the SCP title from the main list to the current page",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["https://scp-wiki.wikidot.com/scp-*"]
    }
  ],
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
